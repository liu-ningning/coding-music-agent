{
  "name": "@music-coding/sidecar",
  "version": "1.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "build:bundle": "esbuild dist/index.js --bundle --platform=node --target=node20 --outfile=dist/bundle.js --format=cjs --external:NeteaseCloudMusicApi",
    "start": "node dist/index.js",
    "build:binary": "bash ../../scripts/build-sidecar.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@music-coding/shared-types": "workspace:*",
    "NeteaseCloudMusicApi": "^4.32.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
